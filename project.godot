[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Items"
2d_physics/layer_4="ScavengeZones"
2d_physics/layer_5="Shelter"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.098, 0.11, 0.13, 1)
2d/snap_2d_transforms_to_pixel=true
2d/snap_2d_vertices_to_pixel=true
